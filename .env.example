# Local realtime API config
HOST=127.0.0.1
PORT=8902

# Set a strong random token in production
API_TOKEN=replace-with-strong-random-token

# Optional: comma-separated allowed origins
# Example: https://maltese.ylongwang.top,https://nonghuangqingyue-ux.github.io
ALLOW_ORIGINS=

# Optional: requests per IP per minute
RATE_LIMIT_PER_MIN=120

# Optional: metrics file path
# DATA_PATH=./data/metrics.json

# Optional: updater interval seconds
METRICS_INTERVAL_SEC=10
